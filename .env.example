# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Banco de dados ─────────────────────────────────────────
DATABASE_URL=postgresql://clinix:clinix@localhost:5432/clinix?schema=public

# ─── Redis / BullMQ ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Twilio (WhatsApp Business API) ─────────────────────────
# Encontre em: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número Twilio no formato WhatsApp: whatsapp:+5511999999999
# Para Sandbox use: whatsapp:+14155238886
TWILIO_FROM_NUMBER=whatsapp:+5511999999999

# ─── Webhook Twilio ──────────────────────────────────────────
# URL pública onde o Twilio entregará as mensagens recebidas.
# Em dev, use ngrok: https://xxxx.ngrok.app/webhooks/twilio
# Configure em: Twilio Console → Messaging → WhatsApp → Sandbox (ou seu número)
TWILIO_WEBHOOK_URL=https://xxxx.ngrok.app/webhooks/twilio

# ─── Fuso horário padrão ────────────────────────────────────
DEFAULT_TIMEZONE=America/Sao_Paulo

# ─── Lembretes ──────────────────────────────────────────────
# Hora do dia para enviar lembrete da véspera (0-23, formato local)
REMINDER_HOUR=18

# ─── Segurança ──────────────────────────────────────────────
# JWT para a API administrativa (painel da clínica)
JWT_SECRET=troque-por-um-segredo-muito-longo-e-aleatorio-min-32-chars
